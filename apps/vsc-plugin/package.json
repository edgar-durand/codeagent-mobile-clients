{
  "name": "codeagent-mobile",
  "displayName": "CodeAgent Mobile",
  "description": "Control your AI coding agents remotely from your mobile device",
  "version": "2.0.0",
  "publisher": "CodeAgentMobile",
  "icon": "resources/icon.png",
  "galleryBanner": {
    "color": "#A78BFA",
    "theme": "dark"
  },
  "preview": false,
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Other"
  ],
  "keywords": [
    "ai",
    "claude",
    "claude-code",
    "copilot",
    "cursor",
    "windsurf",
    "mobile",
    "remote-control",
    "pair-programming",
    "mcp"
  ],
  "homepage": "https://www.codeagent-mobile.com",
  "bugs": {
    "url": "https://github.com/edgar-durand/codeagent-mobile-clients/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/edgar-durand/codeagent-mobile-clients"
  },
  "badges": [
    {
      "url": "https://img.shields.io/visual-studio-marketplace/v/CodeAgentMobile.codeagent-mobile?color=A78BFA&label=VS%20Code%20Marketplace",
      "href": "https://marketplace.visualstudio.com/items?itemName=CodeAgentMobile.codeagent-mobile",
      "description": "VS Code Marketplace version"
    },
    {
      "url": "https://img.shields.io/open-vsx/v/CodeAgentMobile/codeagent-mobile?color=A78BFA&label=Open%20VSX",
      "href": "https://open-vsx.org/extension/CodeAgentMobile/codeagent-mobile",
      "description": "Open VSX version"
    }
  ],
  "sponsor": {
    "url": "https://github.com/sponsors/edgar-durand"
  },
  "qna": "https://github.com/edgar-durand/codeagent-mobile-clients/issues",
  "license": "MIT",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codeagent-mobile",
          "title": "CodeAgent Mobile",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "codeagent-mobile": [
        {
          "type": "webview",
          "id": "codeagent-mobile.panel",
          "name": "CodeAgent Mobile"
        }
      ]
    },
    "commands": [
      {
        "command": "codeagent-mobile.showPairingCode",
        "title": "CodeAgent Mobile: Show Pairing Code"
      },
      {
        "command": "codeagent-mobile.disconnect",
        "title": "CodeAgent Mobile: Disconnect"
      },
      {
        "command": "codeagent-mobile.openPanel",
        "title": "CodeAgent Mobile: Open Panel"
      }
    ],
    "configuration": {
      "title": "CodeAgent Mobile",
      "properties": {
        "codeagent-mobile.apiBaseUrl": {
          "type": "string",
          "default": "https://codeagent-mobile-api.vercel.app",
          "description": "API base URL for the CodeAgent Mobile backend"
        },
        "codeagent-mobile.autoConnect": {
          "type": "boolean",
          "default": true,
          "description": "Automatically reconnect to the last paired session"
        },
        "codeagent-mobile.showNotifications": {
          "type": "boolean",
          "default": true,
          "description": "Show notification messages"
        },
        "codeagent-mobile.heartbeatIntervalMs": {
          "type": "number",
          "default": 30000,
          "description": "Heartbeat interval in milliseconds"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "lint": "eslint src --ext ts",
    "package": "npx @vscode/vsce package --no-dependencies",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@codeagent/shared": "*",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.93.0",
    "@types/ws": "^8.5.10",
    "esbuild": "^0.25.12",
    "typescript": "^6.0.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "ws": "^8.16.0"
  }
}
